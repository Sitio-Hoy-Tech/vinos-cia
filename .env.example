# ===========================
# Supabase
# ===========================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================
# Tenant
# ===========================
NEXT_PUBLIC_TENANT_ID=uuid-del-tenant
NEXT_PUBLIC_SITE_NAME=Nombre del Negocio
NEXT_PUBLIC_URL=https://tu-dominio.com.ar

# ===========================
# Revalidación ISR
# ===========================
REVALIDATION_SECRET=secreto-de-al-menos-24-caracteres

# ===========================
# MercadoPago
# ===========================
MP_ACCESS_TOKEN=TEST-xxx o APP_USR-xxx (producción)
NEXT_PUBLIC_MP_PUBLIC_KEY=TEST-xxx o APP_USR-xxx (producción)
MP_WEBHOOK_SECRET=secreto-del-webhook-mp

# ===========================
# Resend
# ===========================
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@tu-dominio.com
RESEND_FROM_NAME=Nombre del Negocio

# ===========================
# Umami Analytics
# ===========================
NEXT_PUBLIC_UMAMI_WEBSITE_ID=uuid-umami
NEXT_PUBLIC_UMAMI_URL=https://analytics.umami.is
